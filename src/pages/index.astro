---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Software Engineering, First Principles First.</h1>
			<p>
				I’m Dede Ramdani, a Lead Fullstack Engineer with 8+ years of experience building production
				systems in chatbot, e-commerce, and public-sector domains.
			</p>
			<p>
				This site documents practical engineering decisions grounded in credible sources, real-world
				constraints, and production tradeoffs.
			</p>
			<p>
				<a href="/blog">Read blog</a> · <a href="/about">About me</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
