---
const today = new Date();
---

<footer>
	<div>© {today.getFullYear()} Derammd Engineering</div>
	<div class="links">
		<a href="https://github.com/sodrety" target="_blank" rel="noreferrer">GitHub</a>
		<span>·</span>
		<a href="https://www.linkedin.com/in/deramm/" target="_blank" rel="noreferrer">LinkedIn</a>
	</div>
</footer>

<style>
	footer {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 1.25rem 3rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
		border-top: 1px solid rgb(var(--gray-light));
	}

	.links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 0.4rem;
	}

	.links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}

	.links a:hover {
		color: rgb(var(--black));
	}
</style>
